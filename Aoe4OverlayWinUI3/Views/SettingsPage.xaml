<Page
    x:Class="Aoe4OverlayWinUI3.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Aoe4OverlayWinUI3.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <!--  These styles can be referenced to create a consistent SettingsPage layout  -->
        <!--  Reference SettingsExpander Page in Windows Community Toolkit Gallery for the full sample  -->

        <!--  Spacing between cards  -->

        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <!--  Style (inc. the correct spacing) of a section header  -->
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>
    <Grid>
        <ScrollView
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Border>
                <StackPanel
                    x:Name="ContentArea"
                    MaxWidth="1064"
                    Spacing="{StaticResource SettingsCardSpacing}">
                    <StackPanel.ChildrenTransitions>
                        <RepositionThemeTransition />
                    </StackPanel.ChildrenTransitions>
                    <!--  Account  -->
                    <TextBlock x:Uid="Settings_Account_Header" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <toolkit:SettingsCard x:Uid="Settings_Account_SettingsCard">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE77B;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox PlaceholderText="Name" />
                            <Button x:Uid="Settings_Account_SettingsCard_Button" Style="{StaticResource AccentButtonStyle}" />
                            <Border Width="2" />
                            <ProgressRing
                                x:Name="accountSearchProgressRing"
                                Width="20"
                                Height="20"
                                IsActive="False"
                                Visibility="Visible" />
                        </StackPanel>
                    </toolkit:SettingsCard>
                    <!--  Overlay  -->
                    <TextBlock x:Uid="Settings_Overlay_Header" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <toolkit:SettingsCard x:Uid="Settings_Overlay_SettingsCard">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xF156;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="overlayOnOffToggleSwitch" />
                    </toolkit:SettingsCard>
                    <!--  Appearance  -->
                    <TextBlock x:Uid="Settings_Appearance_Header" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <toolkit:SettingsCard x:Uid="Settings_Appearance_SettingsCard">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="themeMode"
                            AutomationProperties.AutomationId="themeModeComboBox"
                            SelectedValue="{x:Bind ViewModel.ElementTheme, Mode=TwoWay}"
                            SelectedValuePath="Tag">
                            <ComboBoxItem x:Uid="Settings_Appearance_ComboBox_Default" Tag="{x:Bind xaml:ElementTheme.Default}" />
                            <ComboBoxItem x:Uid="Settings_Appearance_ComboBox_Light" Tag="{x:Bind xaml:ElementTheme.Light}" />
                            <ComboBoxItem x:Uid="Settings_Appearance_ComboBox_Dark" Tag="{x:Bind xaml:ElementTheme.Dark}" />
                        </ComboBox>
                    </toolkit:SettingsCard>
                    <!--  About  -->
                    <TextBlock x:Uid="Settings_About_Header" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <toolkit:SettingsExpander x:Uid="Settings_About_SettingsExpander" Margin="0,0,0,36">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <BitmapIcon ShowAsMonochrome="False" UriSource="/Assets/WindowIcon.ico" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="False"
                            Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" />
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard
                                x:Name="toCloneRepoCard"
                                Header="To clone this repository"
                                IsClickEnabled="True">
                                <TextBlock
                                    x:Name="gitCloneTextBlock"
                                    FontFamily="Consolas"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Text="git clone https://github.com/framherel/Aoe4OverlayWinUI3" />
                                <toolkit:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="&#xE8C8;" />
                                </toolkit:SettingsCard.ActionIcon>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                x:Name="bugRequestCard"
                                Header="Report a bug or request new feature"
                                IsClickEnabled="True">
                                <toolkit:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="&#xE8A7;" />
                                </toolkit:SettingsCard.ActionIcon>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                HorizontalContentAlignment="Left"
                                ContentAlignment="Vertical"
                                Header="THIS CODE AND INFORMATION IS PROVIDED ‘AS IS’ WITHOUT WARRANTY OF ANY KIND, EITHER EXPRESSED OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE IMPLIED WARRANTIES OF MERCHANTABILITY AND/OR FITNESS FOR A PARTICULAR PURPOSE." />
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>
                </StackPanel>
            </Border>
        </ScrollView>
    </Grid>
</Page>

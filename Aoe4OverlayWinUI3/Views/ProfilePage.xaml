<Page
    x:Class="Aoe4OverlayWinUI3.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="using:Aoe4OverlayWinUI3.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helper:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
    </Page.Resources>

    <!--  TODO: 添加国旗显示  -->
    <!--  TODO: 添加段位显示  -->
    <!--  TODO: 检查无数据时刷新  -->
    <!--  TODO: 增加一个清除按钮，清除当前玩家信息和保存的 ProfileId  -->
    <!--  TODO: 更改 Profile ID 显示方式  -->

    <Grid x:Name="ContentArea">
        <ProgressRing
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <ScrollViewer Visibility="{x:Bind ViewModel.Player, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel Spacing="20">

                <StackPanel Orientation="Horizontal" Spacing="15">
                    <Border
                        Width="80"
                        Height="80"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="4">
                        <FontIcon
                            FontSize="30"
                            Foreground="White"
                            Glyph="&#xE77B;" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <!--  昵称  -->
                        <TextBlock
                            IsTextSelectionEnabled="True"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.Player.Name, Mode=OneWay}" />
                        <!--  国籍  -->
                        <TextBlock
                            Opacity="0.6"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.Player.Country, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
                <!--  分割线  -->
                <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}" />

                <!--  账户信息  -->
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Items>
                        <toolkit:SettingsCard Content="{x:Bind ViewModel.Player.ProfileId, Mode=OneWay}" Header="Profile ID" />

                        <toolkit:SettingsCard Content="{x:Bind ViewModel.Player.SteamId, Mode=OneWay}" Header="Steam ID" />

                        <HyperlinkButton
                            x:Uid="Profile_HyperlinkButton"
                            Margin="4,0,0,0"
                            Foreground="{ThemeResource SystemAccentColor}"
                            NavigateUri="{x:Bind ViewModel.Player.SiteUrl, Mode=OneWay}" />
                    </ItemsControl.Items>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.Player, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}">
            <!--  TODO: 添加多语言  -->
        </StackPanel>
    </Grid>
</Page>

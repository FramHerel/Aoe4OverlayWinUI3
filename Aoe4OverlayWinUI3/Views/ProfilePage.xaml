<Page
    x:Class="Aoe4OverlayWinUI3.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="using:Aoe4OverlayWinUI3.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <helper:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helper:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
    </Page.Resources>


    <Grid x:Name="ContentArea">
        <ProgressRing
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <ScrollViewer Visibility="{x:Bind ViewModel.Player, Mode=OneWay, FallbackValue='加载中...', Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel Margin="24" Spacing="20">

                <StackPanel Orientation="Horizontal" Spacing="15">
                    <Border
                        Width="80"
                        Height="80"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="40">
                        <FontIcon
                            FontSize="40"
                            Foreground="White"
                            Glyph="&#xE77B;" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            IsTextSelectionEnabled="True"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.Player.Name, Mode=OneWay}" />
                        <TextBlock
                            Opacity="0.6"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.Player.Country, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}" />

                <ItemsControl>
                    <toolkit:SettingsCard Content="{x:Bind ViewModel.Player.ProfileId, Mode=OneWay}" Header="Profile ID" />
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.Player, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}">
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="尚未绑定玩家 ID" />
            <Button
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Content="去设置" />
        </StackPanel>
    </Grid>
</Page>

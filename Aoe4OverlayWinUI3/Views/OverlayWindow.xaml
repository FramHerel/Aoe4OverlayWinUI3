<?xml version="1.0" encoding="utf-8" ?>
<windowex:WindowEx
    x:Class="Aoe4OverlayWinUI3.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ViewModel="[ViewModel ]using:Aoe4OverlayWinUI3.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aoe4OverlayWinUI3.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:windowex="using:WinUIEx"
    Title="OverlayWindow"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <windowex:TransparentTintBackdrop TintColor="#554444ff" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border
            x:Name="MainPanel"
            Width="400"
            Height="300"
            Background="{x:Bind ViewModel.BackgroundBrush, Mode=OneWay}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8" />
    </Grid>
</windowex:WindowEx>

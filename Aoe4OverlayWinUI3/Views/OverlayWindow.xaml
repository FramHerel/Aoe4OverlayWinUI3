<?xml version="1.0" encoding="utf-8" ?>
<windowex:WindowEx
    x:Class="Aoe4OverlayWinUI3.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ViewModel="using:Aoe4OverlayWinUI3.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Aoe4OverlayWinUI3.Helpers"
    xmlns:local="using:Aoe4OverlayWinUI3.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Aoe4OverlayWinUI3.Core.Models"
    xmlns:windowex="using:WinUIEx"
    Title="OverlayWindow"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <windowex:TransparentTintBackdrop TintColor="#000000ff" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <DataTemplate x:Key="PlayerItemTemplate" x:DataType="models:LastMatchPlayer">
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image
                        Grid.Column="0"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        Source="{x:Bind CivIconPath, Mode=OneWay}" />

                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Text="{x:Bind DisplayName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />

                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="Orange"
                        Text="{x:Bind Rating, Mode=OneWay}" />
                </Grid>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid x:Name="CustomTitleBar" Grid.Row="0" />

        <Grid Grid.Row="1" Margin="12">
            <StackPanel
                x:Name="LoadingStack"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="11"
                        FontWeight="Bold"
                        Opacity="0.5"
                        Text="TEAM 1" />
                    <ItemsControl ItemTemplate="{StaticResource PlayerItemTemplate}" ItemsSource="{x:Bind ViewModel.CurrentMatch.Teams[0], Mode=OneWay}" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    Margin="0,20,0,0"
                    VerticalAlignment="Center"
                    FontWeight="Black"
                    Opacity="0.3"
                    Text="VS" />

                <StackPanel Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,8"
                        HorizontalAlignment="Right"
                        FontSize="11"
                        FontWeight="Bold"
                        Opacity="0.5"
                        Text="TEAM 2" />
                    <ItemsControl ItemTemplate="{StaticResource PlayerItemTemplate}" ItemsSource="{x:Bind ViewModel.CurrentMatch.Teams[1], Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</windowex:WindowEx>

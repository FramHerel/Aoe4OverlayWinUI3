<?xml version="1.0" encoding="utf-8" ?>
<windowex:WindowEx
    x:Class="Aoe4OverlayWinUI3.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ViewModel="[ViewModel ]using:Aoe4OverlayWinUI3.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aoe4OverlayWinUI3.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:windowex="using:WinUIEx"
    Title="OverlayWindow"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <windowex:TransparentTintBackdrop TintColor="#000000ff" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="Transparent">
            
        </Grid>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Player Name:" FontSize="18" Margin="0,0,0,8" />
            <TextBlock Text="test" FontSize="24" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</windowex:WindowEx>
